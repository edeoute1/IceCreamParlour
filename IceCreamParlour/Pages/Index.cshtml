@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

@section hmabout{
    <div class="container">
        <div class="row" style="margin-top:-50px;">
            <div class="col-md-6">
                <br /><br /><br />
                <h2 class="icecreamintro">Ice-Creams <br />Created With <br />LOVE and FUN!</h2>
